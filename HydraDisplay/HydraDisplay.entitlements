<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Creating virtual displays uses private CoreGraphics APIs that are
	     unavailable inside the App Sandbox. Hydra Display therefore ships
	     unsandboxed, like BetterDisplay and other display tools. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
